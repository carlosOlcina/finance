// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/javascript-node-postgres
{
  "name": "Finance devcontainer",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "features": {
    "ghcr.io/devcontainers-extra/features/expo-cli:1": {},
    "ghcr.io/devcontainers-extra/features/gradle-sdkman:2": {},
    "ghcr.io/devcontainers-extra/features/nx-npm:1": {},
    "ghcr.io/devcontainers-extra/features/springboot-sdkman:2.0.17": {},
    "ghcr.io/devcontainers-extra/features/pnpm:2": {}
  },

  "forwardPorts": [3000, 4321],

  "postCreateCommand": "pnpm install",

  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "nrwl.angular-console",
        "msjsdiag.vscode-react-native",
        "expo.vscode-expo-tools",
        "astro-build.astro-vscode",
        "vscjava.vscode-java-pack",
        "vmware.vscode-boot-dev-pack",
        "ms-ossdata.vscode-pgsql"
      ]
    }
  }

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}
