---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Landing de finanzas construida con Astro, React, Tailwind y desplegada en Vercel.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[var(--surface-950)] text-[var(--text-100)] antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute left-[-12rem] top-24 h-80 w-80 rounded-full bg-[rgba(45,212,191,0.16)] blur-3xl"></div>
      <div class="absolute right-[-8rem] top-[-2rem] h-72 w-72 rounded-full bg-[rgba(246,181,106,0.18)] blur-3xl"></div>
      <div class="absolute bottom-[-10rem] left-1/2 h-72 w-[42rem] -translate-x-1/2 rounded-full bg-[rgba(79,70,229,0.12)] blur-3xl"></div>
    </div>
    <slot />
  </body>
</html>