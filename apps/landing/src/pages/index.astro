---
import HeroSection from '../components/landing/organisms/HeroSection.astro';
import OpenSourceSection from '../components/landing/organisms/OpenSourceSection.astro';
import PillarsSection from '../components/landing/organisms/PillarsSection.astro';
import RailsSection from '../components/landing/organisms/RailsSection.astro';
import TopStrip from '../components/landing/organisms/TopStrip.astro';
import WorkflowSection from '../components/landing/organisms/WorkflowSection.astro';
import YieldPlanner from '../components/react/YieldPlanner';
import {
  heroBuckets,
  heroMethods,
  markers,
  openSourceNotes,
  pillars,
  rails,
  releasesUrl,
  repoUrl,
  workflow,
} from '../data/landingContent';
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Finance | Huchas, medios de dinero y presupuesto simple"
  description="Finance es una app open source para repartir tu dinero en huchas, registrar gastos por apartados y controlar cuentas bancarias y efectivo desde la misma vista."
>
  <main class="pb-16 pt-6 md:pb-24 md:pt-10">
    <TopStrip repoUrl={repoUrl} />
    <HeroSection
      repoUrl={repoUrl}
      releasesUrl={releasesUrl}
      markers={markers}
      heroBuckets={heroBuckets}
      heroMethods={heroMethods}
    />
    <PillarsSection pillars={pillars} />
    <WorkflowSection workflow={workflow} />

    <section id="demo" class="mx-auto max-w-6xl px-6 py-10 md:py-14">
      <YieldPlanner client:visible />
    </section>

    <RailsSection rails={rails} />
    <OpenSourceSection repoUrl={repoUrl} releasesUrl={releasesUrl} notes={openSourceNotes} />
  </main>
</MainLayout>
