---
import type { MarkerItem } from '../../../data/landingContent';

interface Props {
  item: MarkerItem;
}

const { item } = Astro.props;
---

<article class="rounded-[1.7rem] border border-[var(--line)] bg-[var(--surface-card)] p-5 shadow-[var(--shadow-soft)] backdrop-blur">
  <p class="text-xs uppercase tracking-[0.18em] text-[var(--text-300)]">{item.label}</p>
  <p class="mt-4 text-3xl font-semibold text-[var(--text-100)]">{item.value}</p>
  <p class="mt-3 text-sm leading-6 text-[var(--text-300)]">{item.detail}</p>
</article>